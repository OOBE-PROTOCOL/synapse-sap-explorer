# Cap node heap during install/build so esbuild's postinstall version-check
# and `next build` workers don't get SIGKILL'd by the OOM-killer on small
# VPS instances. Without this, `pnpm install --force` and `pnpm build` fail
# with "Error: The service is no longer running" on hosts with <4 GB RAM.
node-options=--max-old-space-size=2048

# Don't crash the whole install if a single optional postinstall script
# (e.g. esbuild --version sanity check) is killed by the OOM-killer.
# The binary itself is already extracted; the postinstall is only a check.
strict-peer-dependencies=false
