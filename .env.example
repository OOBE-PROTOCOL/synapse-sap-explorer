# ──────────────────────────────────────────────────────────
# Synapse SAP Explorer — Environment Configuration
# Copy this file to .env and fill in your values
# ──────────────────────────────────────────────────────────

# ── Synapse SDK (required) ───────────────────────────────
SYNAPSE_API_KEY=sk_live_your-synapse-api-key
SYNAPSE_NETWORK=mainnet
# Accepted: US, US-1, EU, EU-1
SYNAPSE_REGION=US-1

# ── Fallback RPC (optional, strongly recommended) ─────────
# Used by sap-sync when Synapse RPC fails on heavy calls
# (notably getProgramAccounts during Metaplex upstream incidents).
# Recommended: a Helius mainnet URL with ?api-key=…
SAP_FALLBACK_RPC_URL=

# ── Database (required) ──────────────────────────────────
DATABASE_URL=postgresql://user_db_sap_exp:your-password@localhost:5432/DB_SAP_EXP

# ── Indexer mode (optional) ───────────────────────────────
# polling | stream | hybrid
INDEXER_MODE=hybrid
# processed | confirmed | finalized (for grpc stream mode)
INDEXER_GRPC_COMMITMENT=confirmed

# ── Public API v1 (optional) ──────────────────────────────
# Comma-separated fallback keys used only if DB keys table is unavailable.
PUBLIC_API_FREE_KEYS=
PUBLIC_API_PRO_KEYS=
# CORS allowlist for /api/v1/* (comma-separated origins). Use * for open.
PUBLIC_API_CORS_ORIGINS=*

